		"convex": "^1.36.1",
		"convex-helpers": "^0.1.115",
		"convex-svelte": "^0.0.12",
		"embla-carousel-autoplay": "^8.6.0",
		"resend": "^6.12.2",
		"zod": "^4.4.3"
